{
  "mod": "storagenetwork",
  "groups": {
    "ssn_access_blocks": {
      "block": [
        "storagenetwork:inventory",
        "storagenetwork:request"
      ]
    },
    "ssn_remote_items": {
      "item": [
        "storagenetwork:.*_remote"
      ]
    },
    "ssn_upgrade_items": {
      "item": [
        "storagenetwork:.*_upgrade"
      ]
    },
    "ssn_config_blocks": {
      "block": [
        "storagenetwork:master",
        "storagenetwork:storage_kabel",
        "storagenetwork:exchange",
        "storagenetwork:collector",
        "storagenetwork:.*_kabel"
      ]
    },
    "ssn_blocks": {
      "block": ["#ssn_access_blocks", "#ssn_config_blocks"]
    }
  }
}
