{
  "groups": {
    "chests": {
      "block": [".*:chest", ".*:.*_chest", ".*:.*_chest_placeable"],
      "entity": ["minecraft:chest_minecart"]
    },
    "shulkers": {
      "block": [".*:shulker_box", ".*:.*_shulker_box"]
    },
    "barrels": {
      "block": [".*:barrel", ".*:.*_barrel"]
    },
    "doors": {
      "block": [".*:.*_door", ".*:.*_trapdoor"]
    },
    "beds": {
      "block": [".*:.*_bed"]
    },
    "redstone_delays": {
      "block": [".*:repeater", ".*:.*_comparator"]
    },
    "redstone_detectors": {
      "block": [".*:daylight_detector", ".*:.*_note_block"]
    },
    "redstone_switches": {
      "block": [".*:lever", ".*:.*_button", ".*:.*_button_.*", ".*:.*_lever", ".*:.*_lever_.*", ".*:.*_pressure_plate"]
    },
    "redstone_containers": {
      "block": [".*:hopper", ".*:.*_dispenser", ".*:.*_dropper"],
      "entity": [".*:hopper_minecart"]
    },
    "spawn_eggs": {
      "item": [".*:.*_spawn_egg", "minecraft:egg"]
    },
    "xp_orbs": {
      "entity": ["minecraft:experience_orb"]
    },
    "vehicles": {
      "entity": [
        ".*:minecart",
        ".*:.*_minecart",
        ".*:boat",
        ".*:.*_boat",
        "minecraft:pig",
        "minecraft:horse",
        "minecraft:donkey",
        "minecraft:mule",
        "minecraft:strider",
        "minecraft:skeleton_horse",
        "minecraft:zombie_horse",
        "minecraft:llama",
        "minecraft:trader_llama",
        "!minecraft:chest_minecart",
        "!minecraft:hopper_minecart"
      ]
    },
    "furnaces": {
      "block": ["minecraft:furnace", "minecraft:blast_furnace", "minecraft:smoker"]
    },
    "item_frames": {
      "entity": [".*:item_frame", ".*:.*_item_frame"]
    },
    "armor_stands": {
      "entity": ["minecraft:armor_stand"]
    },
    "fence_gates": {
      "block": [
        ".*:.*_fence_gate"
      ]
    }
  }
}
